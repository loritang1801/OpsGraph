# Local persistence used by scripts/run_api.py and the local helper scripts.
OPSGRAPH_DATABASE_URL=sqlite+pysqlite:///./.local/opsgraph.db

# Default to the vendored shared runtime in this repo.
OPSGRAPH_SHARED_CORE_SOURCE=vendored

# Strict local auth defaults for browser and API testing.
OPSGRAPH_AUTH_SECRET=opsgraph-dev-secret
OPSGRAPH_ALLOW_HEADER_AUTH_FALLBACK=false
OPSGRAPH_SEED_DEMO_AUTH=false
OPSGRAPH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
OPSGRAPH_BOOTSTRAP_ADMIN_PASSWORD=opsgraph-dev-admin
OPSGRAPH_BOOTSTRAP_ORG_SLUG=opsgraph
OPSGRAPH_BOOTSTRAP_ORG_NAME=OpsGraph

# Optional OpenAI runtime.
# OPENAI_API_KEY=
# OPSGRAPH_MODEL_PROVIDER=openai
# OPSGRAPH_OPENAI_MODEL=gpt-5.4-mini

# Optional remote provider configuration.
# OPSGRAPH_DEPLOYMENT_LOOKUP_PROVIDER=auto
# OPSGRAPH_DEPLOYMENT_LOOKUP_URL_TEMPLATE=https://deployments.example.test/services/{service_id}/deployments
# OPSGRAPH_DEPLOYMENT_LOOKUP_AUTH_TOKEN=
# OPSGRAPH_SERVICE_REGISTRY_PROVIDER=auto
# OPSGRAPH_SERVICE_REGISTRY_URL_TEMPLATE=https://services.example.test/registry?service={service_id}&query={search_query}&limit={limit}
# OPSGRAPH_SERVICE_REGISTRY_AUTH_TOKEN=
